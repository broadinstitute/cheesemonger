# Byte-compiled / optimized / DLL files
__pycache__/

# Unit test / coverage reports
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Virtual environment
.venv/

# uv lock file is committed, but ignore local cache
.uv/

# CSV files
*.csv

# macOS
.DS_Store

