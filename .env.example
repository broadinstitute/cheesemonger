# Copy to .env for local development:  cp .env.example .env
# Real environment variables and explicit kwargs override these.

# Where datasets and blocks live on disk. The default (/mnt/data) is the
# production Hyperdisk mount and does not exist locally — point it at a
# local path for development.
DATA_DIR=./data

# Taiga dataset ID for the entrez<->symbol gene mapping (optional; leave
# empty to start without a gene mapping loaded). The HGNC complete set is
# parsed via its entrez_id + symbol columns.
TAIGA_GENE_MAPPING_ID=hgnc-gene-table-e250.4/hgnc_complete_set

# Path to a Taiga token file (optional; for Docker/deployment). taigapy reads
# a file named "token" from this file's directory. Local dev defaults to
# ~/.taiga/token if left unset.
TAIGA_TOKEN_PATH=/root/.taiga/token

# Number of threads in the query engine's pool.
# THREAD_POOL_SIZE=4

# Optional path prefix for all routes (e.g. /api/v1).
# API_PREFIX=
